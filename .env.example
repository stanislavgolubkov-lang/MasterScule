APP_NAME="MasterScule Moldova"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

STORE_NAME=MasterScule
STORE_DOMAIN_LABEL=MasterScule.md
STORE_COUNTRY=Moldova
STORE_CURRENCY=MDL
STORE_PHONE="+373 781000 99"
STORE_PHONE_HREF="+37378100099"
STORE_EMAIL=info@masterscule.md
STORE_ADDRESS="Alexandru cel Bun 103/A, Chișinău, Republica Moldova"
STORE_LEGAL_NAME="MasterScule Moldova"

# Set these only when intentionally seeding local/demo accounts.
SEED_ADMIN_PASSWORD=
SEED_CUSTOMER_PASSWORD=

MAIB_BASE_URL=https://api.maib.md
MAIB_CREATE_PAYMENT_PATH=/v2/checkouts
MAIB_PROJECT_ID=
MAIB_SECRET=
MAIB_SIGNATURE_SECRET=
FEATURE_AI_ASSISTANT=false
FEATURE_WISHLIST=false
FEATURE_COMPARE=false
FEATURE_NEWSLETTER=false
PRODUCT_PARSER_MAX_SKU_PER_BATCH=20000
PRODUCT_PARSER_MAX_FILE_SIZE_KB=51200
PRODUCT_PARSER_LOCK_STORE=file
PRODUCT_PARSER_IMAGE_SIZE=1200
PRODUCT_PARSER_PREVIEW_SIZE=600
PRODUCT_PARSER_THUMB_SIZE=300
PRODUCT_PARSER_WEBP_QUALITY=84
PRODUCT_PARSER_WATERMARK_ENABLED=true
PARSER_OFFICIAL_SOURCES_ENABLED=true
PARSER_TRISTOOLS_FALLBACK_ENABLED=true
PARSER_TRISTOOLS_IMAGE_FIRST=false
PARSER_TRISTOOLS_CONTENT_FIRST=false
PARSER_AUTO_APPROVE_EXACT_FALLBACK=false
PARSER_MIN_OFFICIAL_CONFIDENCE=90
PARSER_MIN_FALLBACK_CONFIDENCE=80
PARSER_REQUIRED_IMAGES_FOR_READY=3
PARSER_TRISTOOLS_ENABLED=true
PARSER_TRISTOOLS_BASE_URL=https://tristool.md
PARSER_TRISTOOLS_TIMEOUT=15
PARSER_TRISTOOLS_RATE_LIMIT_MS=1000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# SQLite queue concurrency defaults.
DB_BUSY_TIMEOUT=30000
DB_JOURNAL_MODE=WAL
DB_SYNCHRONOUS=NORMAL
DB_TRANSACTION_MODE=IMMEDIATE
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=1200

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@masterscule.md"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
